{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

// {{ $E }}Client provides CRUD/query operations over {{ $E }} wrapper values.
// It composes over a typed.Client bound to the schema struct: reads wrap the
// schema result, writes forward the wrapper's backing struct.
type {{ $E }}Client struct {
	typed *typed.Client[{{ $sAlias }}.{{ $E }}]
}

// New{{ $E }}Client binds a {{ $E }}Client to conn.
func New{{ $E }}Client(conn modusgraph.Client) *{{ $E }}Client {
	return &{{ $E }}Client{typed: typed.NewClient[{{ $sAlias }}.{{ $E }}](conn)}
}

// Get loads the {{ $E }} with the given UID and returns it wrapped.
func (c *{{ $E }}Client) Get(ctx context.Context, uid string) (*{{ $E }}, error) {
	s, err := c.typed.Get(ctx, uid)
	if err != nil {
		return nil, err
	}
	return Wrap{{ $E }}(s), nil
}

// Add inserts the schema struct backing w.
func (c *{{ $E }}Client) Add(ctx context.Context, w *{{ $E }}) error {
	return c.typed.Add(ctx, w.Unwrap())
}

// Update modifies the schema struct backing w (must have UID set).
func (c *{{ $E }}Client) Update(ctx context.Context, w *{{ $E }}) error {
	return c.typed.Update(ctx, w.Unwrap())
}

// Upsert inserts or updates the schema struct backing w, matching against
// predicates. With no predicates, the first dgraph:"upsert" field wins.
func (c *{{ $E }}Client) Upsert(ctx context.Context, w *{{ $E }}, predicates ...string) error {
	return c.typed.Upsert(ctx, w.Unwrap(), predicates...)
}

// Delete removes the {{ $E }} with the given UID.
func (c *{{ $E }}Client) Delete(ctx context.Context, uid string) error {
	return c.typed.Delete(ctx, uid)
}

// Query returns a wrapper-side query builder for {{ $E }}.
func (c *{{ $E }}Client) Query(ctx context.Context) *{{ $E }}Query {
	return &{{ $E }}Query{typed: c.typed.Query(ctx)}
}

// FulltextFields returns the DQL predicate names of {{ $E }} fields tagged
// with a "fulltext" index, in struct declaration order. Consumers iterate
// this list to build cross-field fulltext queries (e.g. typed.MultiQuery
// search) without hardcoding the field set; adding or removing a fulltext
// tag in the schema flows through on next `make generate`.
func (c *{{ $E }}Client) FulltextFields() []string {
	return []string{
		{{- range .Entity.FulltextPredicates }}
		{{ printf "%q" . }},
		{{- end }}
	}
}
