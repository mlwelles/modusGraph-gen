{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

// {{ $E }}Query is the wrapper-side fluent query builder for {{ $E }}. Builder
// methods return *{{ $E }}Query for chaining; terminal methods (Nodes, First,
// IterNodes) execute the query and wrap results.
type {{ $E }}Query struct {
	typed *typed.Query[{{ $sAlias }}.{{ $E }}]
}

// Filter adds a dgraph @filter expression. params bind to placeholders.
func (q *{{ $E }}Query) Filter(filter string, params ...any) *{{ $E }}Query {
	q.typed.Filter(filter, params...)
	return q
}

// OrderAsc orders results ascending by clause.
func (q *{{ $E }}Query) OrderAsc(clause string) *{{ $E }}Query {
	q.typed.OrderAsc(clause)
	return q
}

// OrderDesc orders results descending by clause.
func (q *{{ $E }}Query) OrderDesc(clause string) *{{ $E }}Query {
	q.typed.OrderDesc(clause)
	return q
}

// Limit caps the number of results.
func (q *{{ $E }}Query) Limit(n int) *{{ $E }}Query {
	q.typed.Limit(n)
	return q
}

// Offset skips the first n results.
func (q *{{ $E }}Query) Offset(n int) *{{ $E }}Query {
	q.typed.Offset(n)
	return q
}

// After returns results with UID greater than uid (cursor pagination).
func (q *{{ $E }}Query) After(uid string) *{{ $E }}Query {
	q.typed.After(uid)
	return q
}

// Cascade drops nodes missing any of the given predicates.
func (q *{{ $E }}Query) Cascade(predicates ...string) *{{ $E }}Query {
	q.typed.Cascade(predicates...)
	return q
}
{{- range edgeFields .Entity.Fields }}

// Where{{ accessorName . }} keeps only {{ $E }} records that have a {{ .Predicate }}
// edge whose target node matches the dgraph @filter expression. params bind to
// $N placeholders. Multiple Where* calls are combined with AND.
func (q *{{ $E }}Query) Where{{ accessorName . }}(filter string, params ...any) *{{ $E }}Query {
	q.typed.WhereEdge("{{ .Predicate }}", filter, params...)
	return q
}

// Where{{ accessorName . }}By keeps only {{ $E }} records that have a {{ .Predicate }}
// edge whose target node matches the filter composed inside build — a typed
// {{ .EdgeEntity }}Query on which By<Field>/Or calls accumulate (ANDing, with Or
// for alternatives). It is the type-safe form of Where{{ accessorName . }}: no
// hand-written DQL or $N placeholders.
func (q *{{ $E }}Query) Where{{ accessorName . }}By(build func(*{{ .EdgeEntity }}Query)) *{{ $E }}Query {
	sub := &{{ .EdgeEntity }}Query{typed: typed.NewDetachedQuery[{{ $sAlias }}.{{ .EdgeEntity }}]()}
	build(sub)
	if expr, params := sub.typed.CombinedFilter(); expr != "" {
		q.typed.WhereEdge("{{ .Predicate }}", expr, params...)
	}
	return q
}
{{- end }}
{{- range filterableScalarFields .Entity.Fields }}

// By{{ accessorName . }} keeps only {{ $E }} records whose {{ .Predicate }} matches one
// of filters. Terms within filters join with OR. Negated filters (Negated:true) become
// NOT eq(...). An empty filters slice is a no-op.
func (q *{{ $E }}Query) By{{ accessorName . }}(filters ...filter.{{ filterTermType . }}) *{{ $E }}Query {
	var b filter.Builder
	b.{{ filterGroupMethod . }}("{{ .Predicate }}", filters)
	if expr, params := b.Build(); expr != "" {
		q.typed.Filter(expr, params...)
	}
	return q
}
{{- end }}

// Or keeps only {{ $E }} records matching at least one of builders. Each builder
// receives a fresh {{ $E }}Query whose By<Field>/Filter calls accumulate (ANDing
// within the builder); the builders' filters are ORed together and the whole
// group ANDs with the rest of the query. Builders that add no filter are
// skipped; an empty Or is a no-op.
func (q *{{ $E }}Query) Or(builders ...func(*{{ $E }}Query)) *{{ $E }}Query {
	subs := make([]*typed.Query[{{ $sAlias }}.{{ $E }}], 0, len(builders))
	for _, build := range builders {
		sub := &{{ $E }}Query{typed: typed.NewDetachedQuery[{{ $sAlias }}.{{ $E }}]()}
		build(sub)
		subs = append(subs, sub.typed)
	}
	q.typed.OrGroup(subs...)
	return q
}

// Nodes executes the query and returns wrapped {{ $E }} results.
func (q *{{ $E }}Query) Nodes() ([]*{{ $E }}, error) {
	recs, err := q.typed.Nodes()
	if err != nil {
		return nil, err
	}
	out := make([]*{{ $E }}, len(recs))
	for i := range recs {
		out[i] = Wrap{{ $E }}(&recs[i])
	}
	return out, nil
}

// First executes the query with an implicit Limit(1) and returns the first
// wrapped {{ $E }}, or nil if no rows matched.
func (q *{{ $E }}Query) First() (*{{ $E }}, error) {
	s, err := q.typed.First()
	if err != nil || s == nil {
		return nil, err
	}
	return Wrap{{ $E }}(s), nil
}

// IterNodes streams the query's results as wrapped {{ $E }} values, paging
// transparently. It is a terminal operation; see typed.Query.IterNodes.
func (q *{{ $E }}Query) IterNodes() iter.Seq2[*{{ $E }}, error] {
	return func(yield func(*{{ $E }}, error) bool) {
		for s, err := range q.typed.IterNodes() {
			if err != nil {
				yield(nil, err)
				return
			}
			if !yield(Wrap{{ $E }}(s), nil) {
				return
			}
		}
	}
}
