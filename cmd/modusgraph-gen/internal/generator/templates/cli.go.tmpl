package {{.CLIPackage}}
{{- $pkg := .}}
{{- $cliExtImports := packageExternalImports $pkg}}

import (
	"bufio"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"os"
	"path/filepath"
	"strings"
	"time"

{{- if .CLIEmitMain}}
	"github.com/alecthomas/kong"
{{- end}}
	"github.com/matthewmcneely/modusgraph"
	"{{.SchemaImportPath}}"
{{range $cliExtImports}}
	{{- if .Alias}}
	{{.Alias}} "{{.Path}}"
	{{- else}}
	"{{.Path}}"
	{{- end}}
{{- end}}
)

// CLI is the root command group. It can be parsed directly by Kong (the
// generated standalone main does this) or embedded anonymously in a larger root
// struct to mount these commands under another binary alongside its own (the
// command fields and the --url/--dir flags are promoted). After parsing, build
// a client with NewClient and pass it to kong's Run so the command bindings
// resolve.
type CLI struct {
	URL string `help:"Dgraph connection URL." default:"dgraph://localhost:9080" env:"DGRAPH_URL"`
	Dir string `help:"Local database directory (embedded mode, mutually exclusive with --url)." env:"DGRAPH_DIR"`

	Query QueryCmd `cmd:"" help:"Execute a raw DQL query."`
{{- range .Entities}}
	{{.Name}} {{.Name}}Cmd `cmd:"" help:"Manage {{.Name}} entities."`
{{- end}}
}

// QueryCmd executes a raw DQL query against the database.
type QueryCmd struct {
	Query   string        `arg:"" optional:"" help:"DQL query string (reads stdin if omitted)."`
	Pretty  bool          `help:"Pretty-print JSON output." default:"true" negatable:""`
	Timeout time.Duration `help:"Query timeout." default:"30s"`
}

func (c *QueryCmd) Run(conn modusgraph.Client) error {
	query := c.Query
	if query == "" {
		// Read from stdin.
		reader := bufio.NewReader(os.Stdin)
		var sb strings.Builder
		for {
			line, err := reader.ReadString('\n')
			sb.WriteString(line)
			if err != nil {
				if err != io.EOF {
					return fmt.Errorf("reading stdin: %w", err)
				}
				break
			}
		}
		query = strings.TrimSpace(sb.String())
	}

	if query == "" {
		return fmt.Errorf("empty query: provide a DQL query as an argument or via stdin")
	}

	ctx, cancel := context.WithTimeout(context.Background(), c.Timeout)
	defer cancel()

	resp, err := conn.QueryRaw(ctx, query, nil)
	if err != nil {
		return err
	}

	if c.Pretty {
		var data any
		if err := json.Unmarshal(resp, &data); err != nil {
			return fmt.Errorf("parsing response: %w", err)
		}
		enc := json.NewEncoder(os.Stdout)
		enc.SetIndent("", "  ")
		return enc.Encode(data)
	}
	_, err = fmt.Println(string(resp))
	return err
}

{{range .Entities}}
// {{.Name}}Cmd groups subcommands for {{.Name}}.
type {{.Name}}Cmd struct {
	Get    {{.Name}}GetCmd    `cmd:"" help:"Get a {{.Name}} by UID."`
	List   {{.Name}}ListCmd   `cmd:"" help:"List {{.Name}} entities."`
	Add    {{.Name}}AddCmd    `cmd:"" help:"Add a new {{.Name}}."`
	Delete {{.Name}}DeleteCmd `cmd:"" help:"Delete a {{.Name}} by UID."`
}

type {{.Name}}GetCmd struct {
	UID string `arg:"" required:"" help:"The UID of the {{.Name}}."`
}

func (c *{{.Name}}GetCmd) Run(client *{{$.Name}}.Client) error {
	result, err := client.{{.Name}}.Get(context.Background(), c.UID)
	if err != nil {
		return err
	}
	return printJSON(result)
}

type {{.Name}}ListCmd struct{}

func (c *{{.Name}}ListCmd) Run(client *{{$.Name}}.Client) error {
	recs, err := client.{{.Name}}.Query(context.Background()).Nodes()
	if err != nil {
		return err
	}
	return printJSON(recs)
}

type {{.Name}}AddCmd struct {
{{- range nonSliceScalarFields .Fields}}{{if and (not .IsUID) (not .IsDType) (cliSettable .GoType)}}
	{{- if .IsPrivate}}
	{{. | accessorName}} {{cliType .GoType}} `help:"Set {{.Name}}." name:"{{toLower .Name}}"`
	{{- else}}
	{{.Name}} {{cliType .GoType}} `help:"Set {{.Name}}." name:"{{toLower .Name}}"`
	{{- end}}
{{- end}}{{end}}
}

func (c *{{.Name}}AddCmd) Run(client *{{$.Name}}.Client) error {
	e := &{{$.Name}}.{{.Name}}{}
{{- range nonSliceScalarFields .Fields}}{{if and (not .IsUID) (not .IsDType) (cliSettable .GoType)}}
	{{- if contains .GoType "time."}}
	if c.{{if .IsPrivate}}{{. | accessorName}}{{else}}{{.Name}}{{end}} != "" {
		parsed, err := time.Parse(time.RFC3339, c.{{if .IsPrivate}}{{. | accessorName}}{{else}}{{.Name}}{{end}})
		if err != nil {
			return fmt.Errorf("invalid time for {{.Name}}: %w", err)
		}
		e.{{if .IsPrivate}}{{. | accessorName}}{{else}}{{.Name}}{{end}} = parsed
	}
	{{- else if .IsPrivate}}
	e.{{. | accessorName}} = {{cliConvert .GoType (print "c." (. | accessorName))}}
	{{- else}}
	e.{{.Name}} = {{cliConvert .GoType (print "c." .Name)}}
	{{- end}}
{{- end}}{{end}}
	if err := client.{{.Name}}.Add(context.Background(), e); err != nil {
		return err
	}
	return printJSON(e)
}

type {{.Name}}DeleteCmd struct {
	UID string `arg:"" required:"" help:"The UID to delete."`
}

func (c *{{.Name}}DeleteCmd) Run(client *{{$.Name}}.Client) error {
	return client.{{.Name}}.Delete(context.Background(), c.UID)
}
{{end}}

func printJSON(v any) error {
	enc := json.NewEncoder(os.Stdout)
	enc.SetIndent("", "  ")
	return enc.Encode(v)
}

// ConnectString resolves the Dgraph connection string from the --url/--dir
// flags, enforcing that they are mutually exclusive.
func (c *CLI) ConnectString() (string, error) {
	if c.Dir != "" {
		if c.URL != "dgraph://localhost:9080" {
			return "", fmt.Errorf("--url and --dir are mutually exclusive")
		}
		return fmt.Sprintf("file://%s", filepath.Clean(c.Dir)), nil
	}
	return c.URL, nil
}

// NewClient opens a modusgraph client from the CLI's connection flags. Pass the
// returned client (and the schema client built from it) to kong's Run so the
// generated command bindings resolve. The caller owns Close.
func (c *CLI) NewClient() (modusgraph.Client, error) {
	connStr, err := c.ConnectString()
	if err != nil {
		return nil, err
	}
	return modusgraph.NewClient(connStr,
		modusgraph.WithAutoSchema(true),
{{- if .WithValidator}}
		modusgraph.WithValidator(modusgraph.NewValidator()),
{{- end}}
	)
}
{{if .CLIEmitMain}}
func main() {
	var cli CLI
	ctx := kong.Parse(&cli,
		kong.Name("{{.CLIName}}"),
		kong.Description("CLI for the {{.CLIName}} data model."),
	)

	conn, err := cli.NewClient()
	if err != nil {
		fmt.Fprintf(os.Stderr, "connect: %v\n", err)
		os.Exit(1)
	}
	defer conn.Close()

	client := {{.Name}}.NewClient(conn)

	err = ctx.Run(conn, client)
	ctx.FatalIfErrorf(err)
}
{{- end}}
