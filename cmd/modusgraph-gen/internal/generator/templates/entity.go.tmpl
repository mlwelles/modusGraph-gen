{{- $E := .Entity.Name }}
{{- $sAlias := .SchemaAlias }}

// {{ $E }} wraps a {{ $sAlias }}.{{ $E }} and exposes its data through methods.
// It embeds typed.Wrapper, which supplies Unwrap, JSON marshaling, and
// validation; the backing schema struct is reachable only via Unwrap().
type {{ $E }} struct {
	typed.Wrapper[{{ $sAlias }}.{{ $E }}]
}

// New{{ $E }} constructs a {{ $E }} with a fresh, empty schema struct, then
// applies the given options.
func New{{ $E }}(opts ...typed.Option[{{ $E }}]) *{{ $E }} {
	e := &{{ $E }}{Wrapper: typed.WrapValue(&{{ $sAlias }}.{{ $E }}{})}
	typed.Apply(e, opts...)
	return e
}

// Wrap{{ $E }} constructs a {{ $E }} backed by the given schema struct, then
// applies the given options. The wrapper holds s directly — no defensive
// copy, so setters mutate the caller's struct.
func Wrap{{ $E }}(s *{{ $sAlias }}.{{ $E }}, opts ...typed.Option[{{ $E }}]) *{{ $E }} {
	e := &{{ $E }}{Wrapper: typed.WrapValue(s)}
	typed.Apply(e, opts...)
	return e
}

// UID returns the entity's UID bookkeeping field.
func (e *{{ $E }}) UID() string { return e.Unwrap().UID }

// SetUID sets the entity's UID bookkeeping field.
func (e *{{ $E }}) SetUID(v string) { e.Unwrap().UID = v }

// DType returns the entity's dgraph type list.
func (e *{{ $E }}) DType() []string { return e.Unwrap().DType }

// SetDType sets the entity's dgraph type list.
func (e *{{ $E }}) SetDType(v []string) { e.Unwrap().DType = v }
